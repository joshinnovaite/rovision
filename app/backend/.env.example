# Orba CMMS integration — copy to app/backend/.env and fill in.
# These three values are owed by the Orba developer once Orba is deployed.
# app/backend/.env is gitignored; keep the real secret out of git.

# Deployed Orba base URL, e.g. https://orba-you.vercel.app (no trailing slash needed).
# For local stub testing: http://localhost:3000
ORBA_BASE_URL=

# Shared secret guarding Orba's write routes. Sent as Authorization: Bearer <secret>.
# Leave blank if Orba has no auth yet.
ORBA_INGEST_SECRET=

# A real assetnum at site BEDFORD (from Orba's seeded assets). Every video the demo
# sends findings for is filed against this single asset.
ORBA_ASSETNUM=
